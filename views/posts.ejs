<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>

    <h1>Wellcome</h1>

    <form method="post" action="http://localhost:3000/posts/add">
        <input type="text" name="name" id="" placeholder="enter your name">
        <input type="text" name="age" placeholder="enter age">
        <input type="text" name="contant" placeholder="write your contant" style="width: 8cm; height: 2cm; margin: 2px;">
        <button type="submit">Add</button>
    </form>

    <br>
    <br>
    <div>
        <% for(post of posts){%>
        <div style="border: 2px solid green; margin: 1px;">
            <h3>Name: <%= post.name%> || Age: <%=post.age%></h3>
            
            <h3>Contant: <%= post.contant%></h3>

            <a href="http://localhost:3000/posts/views/<%=post.id%>" style="margin: 4px;" >See in Detail</a>
            <a href="http://localhost:3000/posts/<%=post.id%>/edit" style="margin: 4px;">Edit</a>
            
            <br>
            <br>  
            <form method="post" action="/posts/<%=post.id%>?_method=DELETE">
                <button type="submit">Submit</button>
            </form>
        </div>
        <%}%>
    </div>
</body>
</html>